# Copy to brain/.env and fill in. NEVER commit .env. (Live API keys live only in the
# Cloudflare Worker, never the browser; these brain-side keys are for batch calls only.)

# --- Neo4j (Neo4j Desktop: set NEO4J_PASSWORD to the password you chose when creating the
#     local instance; URI/USER are the Neo4j Desktop defaults) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# --- DeepSeek (batch extraction/adjudication; Phase 2+) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- ElevenLabs (voice; Phase 7, used by the Worker, not the brain) ---
ELEVENLABS_API_KEY=

# --- Sync bus (Phase 8) ---
BUS_ROOT=./_bus
