# Copy to brain/.env and fill in. NEVER commit .env. (Live API keys live only in the
# Cloudflare Worker, never the browser; these brain-side keys are for batch calls only.)

# --- Knowledge graph (P12): an OKF Markdown bundle — no database server. Defaults to
#     {BUS_ROOT}/graph (inside the Drive-synced engagement folder, so it backs up for free).
#     Uncomment to keep the graph somewhere else, e.g. local-only:
# GRAPH_ROOT=./_state/graph

# --- DeepSeek (batch extraction/adjudication; Phase 2+) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- ElevenLabs (voice; Phase 7, used by the Worker, not the brain) ---
ELEVENLABS_API_KEY=

# --- Sync bus (Phase 8) ---
BUS_ROOT=./_bus
