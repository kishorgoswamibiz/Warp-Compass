{
  "name": "warp-compass-pwa",
  "private": true,
  "version": "0.1.0",
  "description": "Warp Compass — the interaction plane (installable voice PWA). Fast live runner; holds NO graph.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cf": "wrangler pages dev -- npm run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "typecheck": "tsc -b --noEmit",
    "typecheck:functions": "tsc -p functions/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "session": "tsx src/runner/harness.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^2.0.5",
    "wrangler": "^3.114.0"
  }
}
